# ─────────────────────────────────────────────────────────────
#  PaperPicks — environment template
#  Copy this file to `.env.local` and fill in your real values.
#  `.env.local` is gitignored, so your secrets never get committed.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──  (Supabase dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 🔴 SECRET — server only. Bypasses all security. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic (Claude) ──  (console.anthropic.com → API keys)
# 🔴 SECRET — Claude judges papers (importance/replicability + one-line reason).
ANTHROPIC_API_KEY=

# ── Google Gemini ──  (aistudio.google.com → Get API key)
# 🔴 SECRET — search embeddings only (gemini-embedding-2).
GEMINI_API_KEY=

# ── Semantic Scholar (recommended) ──  (semanticscholar.org/product/api)
# Raises the citation-fetch rate limit. Without it, the weekly citations step
# 429s once the corpus is large. Weekly job only (not needed on Vercel).
SEMANTIC_SCHOLAR_API_KEY=

# ── Auth (magic-link owner gate) ──
# Only this email may curate (👍 / 👎). Leave unset to allow any signed-in user.
ALLOWED_EMAIL=

# ── GitHub (optional) ──  (github.com → Settings → Developer settings → tokens)
# Raises the GitHub-stars fetch rate limit. Unauthenticated works but is slower.
GITHUB_TOKEN=

# ── "Run now" watch button (optional) ──  goes in VERCEL, not the weekly job
# Fine-grained PAT with "Actions: write" on your repo. Lets the app trigger an
# on-demand watch ingest+judge run. GH_REPO defaults to shivam7569/paperpicks.
GH_DISPATCH_TOKEN=
GH_REPO=

# ── Corpus pruning (optional) ──  belongs in the GITHUB ACTIONS (weekly job) env
# Delete unjudged + unvoted corpus papers whose publish date is older than this
# many days (default 1095 ≈ 3 years). Judged picks + anything you voted on are
# ALWAYS kept. Lower this if you approach the Supabase free-tier storage cap.
PRUNE_MAX_AGE_DAYS=
